<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1, user-scalable=no, viewport-fit=cover, interactive-widget=resizes-content"/>
    <title>БГ-2026 КумКВата</title>
    <base href="~/"/>

    <style>
        html, body {
            height: 100vh;
